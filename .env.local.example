# Supabase — already set on Vercel by the integration. For local dev, copy this
# file to .env.local and fill in values (Supabase Dashboard → Project Settings → API),
# or run:  vercel env pull .env.local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Comma-separated list of emails allowed to sign in to /admin.
# Anyone not on this list is rejected even if they request a magic link.
ADMIN_EMAILS=owner@example.com
